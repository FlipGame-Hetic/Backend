# ─── API ───────────────────────────────────────────────────────────────────────
API_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# Required — minimum 32 characters, no default: openssl rand -base64 48
SCREEN_JWT_SECRET=

# ─── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to enforce DATABASE_URL / DATABASE_HOST (no SQLite fallback)
APP_ENV=development

# ─── Database — option A: full URL ─────────────────────────────────────────────
# DATABASE_URL=sqlite:///data/flipper.db

# ─── Database — option B: PostgreSQL by parts ──────────────────────────────────
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=flipper
# DATABASE_USER=flipper
# DATABASE_PASSWORD=

# ─── MQTT (mqtt-bridge) ────────────────────────────────────────────────────────
# MQTT_HOST=mosquitto
# MQTT_PORT=1883
# MQTT_CLIENT_ID=mqtt-bridge
