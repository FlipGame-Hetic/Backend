# API
API_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# Required — min 32 chars: openssl rand -base64 48
SCREEN_JWT_SECRET=

# SQLite database file path
# Defaults to sqlite:///data/flipper.db if not set.
# The /data directory is mounted as a named Docker volume to persist data across deployments.
# DATABASE_URL=sqlite:///data/flipper.db

# MQTT (mqtt-bridge)
# MQTT_HOST=mosquitto
# MQTT_PORT=1883
# MQTT_CLIENT_ID=mqtt-bridge
